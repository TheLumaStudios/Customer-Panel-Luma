{
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/delivery-return", "destination": "/delivery-return.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install"
}
